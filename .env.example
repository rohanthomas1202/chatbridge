# ChatBridge Environment Variables
# Copy this file to .env and fill in your values.

# ─── AI Provider Keys ──────────────────────────────────────────────
# At least one provider key is required for the chat to work.

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# ─── Plugin Configuration ──────────────────────────────────────────

# Spotify Plugin (OAuth2 PKCE)
# Create an app at https://developer.spotify.com/dashboard
# Set redirect URI to: https://your-domain.com/plugins/spotify/callback
VITE_SPOTIFY_CLIENT_ID=

# ─── Build Configuration ───────────────────────────────────────────

# Build target: "web" for browser deployment, omit for Electron
# CHATBOX_BUILD_PLATFORM=web

# ─── Optional Services ─────────────────────────────────────────────

# Sentry error tracking
# SENTRY_AUTH_TOKEN=
# SENTRY_DSN=
